DATABASE_URL=postgres://filmtracker:filmtracker@localhost:5432/filmtracker
PORT=4000
# 0.0.0.0 accepts connections from your LAN (default). Use 127.0.0.1 to block remote devices.
LISTEN_HOST=0.0.0.0
# Comma-separated browser origins. Private LAN origins (192.168.x, 10.x, 172.16–31.x) are also allowed unless ALLOW_LAN_ORIGINS=false.
WEB_ORIGIN=http://localhost:5173
ALLOW_LAN_ORIGINS=true
# Comma-separated hours (0–23), server local time. Default 0,12 = twice daily at midnight and noon.
SCRAPE_HOURS=0,12

